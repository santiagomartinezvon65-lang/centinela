{
  "id": "traefik-dashboard",
  "info": {
    "name": "Traefik dashboard expuesto",
    "severity": "medium",
    "category": "disclosure",
    "remediation": "Restringí el acceso (auth/VPN/firewall); este recurso no debería ser público."
  },
  "requests": [
    {
      "method": "GET",
      "path": "/dashboard/",
      "matchers_condition": "and",
      "matchers": [
        {
          "type": "status",
          "status": [
            200
          ]
        },
        {
          "type": "word",
          "part": "body",
          "words": [
            "traefik",
            "Traefik"
          ],
          "condition": "or"
        }
      ]
    }
  ]
}