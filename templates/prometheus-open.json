{
  "id": "prometheus-open",
  "info": {
    "name": "Prometheus expuesto",
    "severity": "medium",
    "category": "disclosure",
    "remediation": "Restringí el acceso (auth/VPN/firewall); este recurso no debería ser público."
  },
  "requests": [
    {
      "method": "GET",
      "path": "/graph",
      "matchers_condition": "and",
      "matchers": [
        {
          "type": "status",
          "status": [
            200
          ]
        },
        {
          "type": "word",
          "part": "body",
          "words": [
            "Prometheus Time Series",
            "prometheus"
          ],
          "condition": "or"
        }
      ]
    }
  ]
}