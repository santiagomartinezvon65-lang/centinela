{
  "id": "jenkins-panel",
  "info": {
    "name": "Jenkins detectado",
    "severity": "low",
    "category": "disclosure",
    "remediation": "Restringí el acceso (auth/VPN/firewall); este recurso no debería ser público."
  },
  "requests": [
    {
      "method": "GET",
      "path": "/login?from=%2F",
      "matchers_condition": "and",
      "matchers": [
        {
          "type": "status",
          "status": [
            200
          ]
        },
        {
          "type": "word",
          "part": "body",
          "words": [
            "Jenkins-Crumb",
            "jenkins",
            "Dashboard [Jenkins]"
          ],
          "condition": "or"
        }
      ]
    }
  ]
}