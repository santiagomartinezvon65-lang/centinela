{
  "id": "kibana-panel",
  "info": {
    "name": "Kibana detectado",
    "severity": "low",
    "category": "disclosure",
    "remediation": "Restringí el acceso (auth/VPN/firewall); este recurso no debería ser público."
  },
  "requests": [
    {
      "method": "GET",
      "path": "/app/kibana",
      "matchers_condition": "and",
      "matchers": [
        {
          "type": "status",
          "status": [
            200
          ]
        },
        {
          "type": "word",
          "part": "body",
          "words": [
            "kbnLoadingMessage",
            "kibana"
          ],
          "condition": "or"
        }
      ]
    }
  ]
}