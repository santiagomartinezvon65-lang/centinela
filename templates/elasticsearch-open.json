{
  "id": "elasticsearch-open",
  "info": {
    "name": "Elasticsearch expuesto sin autenticación",
    "severity": "high",
    "category": "disclosure",
    "remediation": "Restringí el acceso (auth/VPN/firewall); este recurso no debería ser público."
  },
  "requests": [
    {
      "method": "GET",
      "path": "/",
      "matchers_condition": "and",
      "matchers": [
        {
          "type": "status",
          "status": [
            200
          ]
        },
        {
          "type": "word",
          "part": "body",
          "words": [
            "cluster_name",
            "lucene_version"
          ],
          "condition": "and"
        }
      ]
    }
  ]
}