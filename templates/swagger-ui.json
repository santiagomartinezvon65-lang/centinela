{
  "id": "swagger-ui",
  "info": {
    "name": "Swagger UI expuesto",
    "severity": "low",
    "category": "disclosure",
    "remediation": "Restringí el acceso (auth/VPN/firewall); este recurso no debería ser público."
  },
  "requests": [
    {
      "method": "GET",
      "path": "/swagger-ui/index.html",
      "matchers_condition": "and",
      "matchers": [
        {
          "type": "status",
          "status": [
            200
          ]
        },
        {
          "type": "word",
          "part": "body",
          "words": [
            "Swagger UI",
            "swagger-ui"
          ],
          "condition": "or"
        }
      ]
    }
  ]
}